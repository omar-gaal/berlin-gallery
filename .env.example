# Railway S3-Compatible Storage Configuration
# 
# These environment variables are required for the image storage system.
# Copy this file to .env.local and fill in the actual values from your Railway console.
# 
# Never commit .env or .env.local files—only .env.example should be tracked in git.

# The endpoint URL for Railway's S3-compatible storage service
# Example: https://s3.railway.app
AWS_ENDPOINT_URL=

# The name of the S3 bucket where images will be stored
# Example: berlin-gallery-images
AWS_S3_BUCKET_NAME=

# The AWS region for the S3 service (typically us-east-1 for Railway)
AWS_DEFAULT_REGION=

# AWS access key ID for authentication (provided by Railway)
AWS_ACCESS_KEY_ID=

# AWS secret access key for authentication (provided by Railway)
# Keep this value confidential—never commit it to git
AWS_SECRET_ACCESS_KEY=
